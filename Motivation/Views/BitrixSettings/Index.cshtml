@model BitrixSettingsViewModel
@{
    ViewData["Title"] = "Настройки синхронизации Bitrix24";
}

<div class="pagetitle">
    <h1>Настройки синхронизации Bitrix24</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Главная</a></li>
            <li class="breadcrumb-item active">Настройки Bitrix24</li>
        </ol>
    </nav>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<section class="section dashboard">
    <div class="row">
        <!-- Настройки синхронизации -->
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Общие настройки синхронизации</h5>
                    <form asp-action="Update" asp-controller="BitrixSettings" method="post">
                        <input type="hidden" asp-for="Settings.Id" />
                        
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" asp-for="Settings.Enabled" id="Enabled">
                            <label class="form-check-label" for="Enabled">Включить синхронизацию</label>
                        </div>

                        <div class="mb-3">
                            <label for="WebhookUrl" class="form-label">URL вебхука</label>
                            <input type="url" class="form-control" asp-for="Settings.WebhookUrl" id="WebhookUrl" required>
                        </div>

                        <div class="mb-3">
                            <label for="SyncIntervalMinutes" class="form-label">Интервал синхронизации (минуты)</label>
                            <input type="number" class="form-control" asp-for="Settings.SyncIntervalMinutes" id="SyncIntervalMinutes" min="1">
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" asp-for="Settings.SyncTasks" id="SyncTasks">
                            <label class="form-check-label" for="SyncTasks">Синхронизировать задачи</label>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" asp-for="Settings.SyncDeals" id="SyncDeals">
                            <label class="form-check-label" for="SyncDeals">Синхронизировать сделки</label>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" asp-for="Settings.TwoWaySync" id="TwoWaySync">
                            <label class="form-check-label" for="TwoWaySync">Двусторонняя синхронизация</label>
                        </div>

                        <button type="submit" class="btn btn-primary">Сохранить настройки</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Порталы -->
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">Порталы Bitrix24</h5>
                        <a asp-action="AddPortal" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Добавить портал
                        </a>
                    </div>

                    @if (Model.Portals.Any())
                    {
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>URL портала</th>
                                    <th>Вебхук</th>
                                    <th>Активен</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var portal in Model.Portals)
                                {
                                    <tr>
                                        <td>@portal.Name</td>
                                        <td>@portal.PortalUrl</td>
                                        <td>@(string.IsNullOrEmpty(portal.WebhookUrl) ? "-" : portal.WebhookUrl.Substring(0, Math.Min(30, portal.WebhookUrl.Length)) + "...")</td>
                                        <td>
                                            @if (portal.IsActive)
                                            {
                                                <span class="badge bg-success">Активен</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Неактивен</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!portal.IsActive)
                                            {
                                                <form asp-action="SetActivePortal" asp-controller="BitrixSettings" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@portal.Id" />
                                                    <button type="submit" class="btn btn-sm btn-primary">Сделать активным</button>
                                                </form>
                                            }
                                            <a asp-action="EditPortal" asp-route-id="@portal.Id" class="btn btn-sm btn-warning">Изменить</a>
                                            <form asp-action="DeletePortal" asp-controller="BitrixSettings" method="post" style="display:inline;" onsubmit="return confirm('Вы уверены?');">
                                                <input type="hidden" name="id" value="@portal.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">Порталы не добавлены</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
