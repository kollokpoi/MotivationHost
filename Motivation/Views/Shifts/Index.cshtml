@model ShiftsViewModel
@{
    ViewData["Title"] = "Рабочее время";
}

<div class="container-fluid">
    <div class="row px-0">
        <div class="col-auto me-auto ps-0">
            <div class="pagetitle">
                <h1>@ViewData["Title"]</h1>
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">Компания</li>
                        <li class="breadcrumb-item active">@ViewData["Title"]</li>
                    </ol>
                </nav>
            </div>
        </div>

        <div class="col-md-auto col-sm-12 pe-0 hidden-mobile">
            <a asp-controller="Shifts" asp-action="Export" asp-route-year="@Model.StartDate.Year" asp-route-month="@Model.StartDate.Month" class="btn btn-primary" role="button">
                <i class="bi bi-cloud-arrow-up me-2"></i>Экспортировать
            </a>
        </div>
    </div>

    <div class="row">
        <div class="card card-full">
            <div class="card-body">
                <div class="date-info">
                    <a class="me-2" asp-controller="Shifts" asp-action="Index" asp-route-year="@Model.StartDate.AddMonths(-1).Year" asp-route-month="@Model.StartDate.AddMonths(-1).Month">
                        <i class="bi bi-chevron-left switch-date-button"></i>
                    </a>

                    <h5 class="card-title">@Model.StartDate.ToString("d") - @Model.EndDate.ToString("d")</h5>

                    @if (Model.EndDate < DateTime.Now)
                    {
                        <a class="ms-2" asp-controller="Shifts" asp-action="Index" asp-route-year="@Model.StartDate.AddMonths(1).Year" asp-route-month="@Model.StartDate.AddMonths(1).Month">
                            <i class="bi bi-chevron-right switch-date-button"></i>
                        </a>
                    }
                </div>

                <section class="section dashboard">
                    <table class="table table-bordered table-responsive align-middle">
                        <colgroup>
                            <col />
                            <col />
                            <col />
                            @{
                                var dates = new List<DateTime>();
                                for (var dt = Model.StartDate; dt <= Model.EndDate; dt = dt.AddDays(1))
                                {
                                    dates.Add(dt);
                                }

                                var daysOfWeek = new Dictionary<DayOfWeek, string>
                            {
                            {DayOfWeek.Monday, "ПН" },
                            {DayOfWeek.Tuesday, "ВТ" },
                            {DayOfWeek.Wednesday, "СР" },
                            {DayOfWeek.Thursday, "ЧТ" },
                            {DayOfWeek.Friday, "ПТ" },
                            {DayOfWeek.Saturday, "СБ" },
                            {DayOfWeek.Sunday, "ВС" },
                            };

                                foreach (var date in dates)
                                {
                                    var dayOfWeek = date.DayOfWeek;
                                    <col class="@(dayOfWeek == DayOfWeek.Sunday || dayOfWeek == DayOfWeek.Saturday ? "weekend-col" : string.Empty )" />
                                }
                            }
                        </colgroup>
                        <thead>
                            <tr>
                                <th style="vertical-align: middle;" class="text-center">
                                    Сотрудники
                                </th>

                                <th style="vertical-align: middle;" class="text-center">
                                    График
                                </th>

                                <th style="vertical-align: middle;" class="text-center">
                                    Итого
                                </th>

                                @{
                                    foreach (var date in dates)
                                    {
                                        var dayOfWeek = date.DayOfWeek;
                                        <th class="text-center">
                                            <div style="font-size:small">@daysOfWeek[date.DayOfWeek]</div>
                                            <div style="font-size:small">@date.Day.ToString("00")</div>
                                        </th>
                                    }
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @if (!Model.EmployeesShifts.Any())
                            {
                                <tr>
                                    <td>Тут пока никого нет</td>
                                    <td></td>
                                </tr>
                            }

                            @foreach (var employeeShifts in Model.EmployeesShifts)
                            {
                                var employee = employeeShifts.Employee;
                                <tr>
                                    <td style="vertical-align: middle;" width="15%">
                                        <div class="row align-items-center">
                                            <div class="col-3">
                                                <img src="@(string.IsNullOrEmpty(employeeShifts.Employee.Photo) ? "~/images/profile.png" : employeeShifts.Employee.Photo)" alt="Profile" class="rounded-circle" width="50" height="50">
                                            </div>
                                            <div class="col-8">
                                                @employee.GetShortName()@* <br><span style="font-size: 14px; color: #888888">@employeeShifts.Employee.Email</span> *@
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        @employee.StartTime.ToLocalTime().ToString("HH:mm") <br class="p-0"/>@employee.EndTime.ToLocalTime().ToString("HH:mm")
                                    </td>

                                    <td class="text-center">
                                        @employeeShifts.WorkingHours.Sum()
                                    </td>


                                    @for (int i = 0; i < employeeShifts.WorkingHours.Count; i++)
                                    {
                                        var workingTime = employeeShifts.WorkingHours[i];

                                        if (workingTime == 0)
                                        {
                                            <td class="text-center"></td>
                                        }
                                        else
                                        {
                                            var comment = employeeShifts.Comments[i];
                                            if (string.IsNullOrEmpty(comment))
                                            {
                                                <td class="text-center">@workingTime</td>
                                            }
                                            else
                                            {
                                                <td class="text-center bad-shift"
                                                    data-bs-toggle="tooltip"
                                                    data-bs-placement="bottom"
                                                    data-bs-custom-class="custom-tooltip"
                                                    data-bs-html="true"
                                                    data-bs-title="@comment">
                                                    @workingTime
                                                </td>
                                            }
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </section>
            </div>
        </div>
    </div>
</div>