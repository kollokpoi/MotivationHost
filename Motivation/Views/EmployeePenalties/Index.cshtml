@model EmployeePenaltiesViewModel
@{
    ViewData["Title"] = "Замечания";
}

<div class="container-fluid">
    <div class="row px-0">
        <div class="col-auto me-auto ps-0">
            <div class="pagetitle">
                <h1>Замечания</h1>
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">Компания</li>
                        <li class="breadcrumb-item active">@ViewData["Title"]</li>
                    </ol>
                </nav>
            </div>
        </div>

        <div class="col-md-auto col-sm-12 pe-0 hidden-mobile">
            <a asp-controller="EmployeePenalties" asp-action="Add" class="btn btn-primary" role="button">
                <i class="bi bi-plus-lg me-2"></i>Добавить
            </a>
        </div>
    </div>

    <div class="row">
        <div class="card mb-4 p-3">
            <form method="get" asp-controller="EmployeePenalties" asp-action="Index">
                <div class="d-flex align-items-center gap-3">
                    <a asp-action="Index" asp-route-year="@(ViewBag.Year - (ViewBag.Month == 1 ? 1 : 0))"
                        asp-route-month="@(ViewBag.Month == 1 ? 12 : ViewBag.Month - 1)"
                        class="btn btn-outline-secondary">
                        <i class="bi bi-chevron-left"></i>
                    </a>

                    <select id="month" name="month" class="form-select w-auto">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == ViewBag.Month ? "selected" : null)">
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
                            </option>
                        }
                    </select>

                    <select id="year" name="year" class="form-select w-auto">
                        @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year; y++)
                        {
                            <option value="@y" selected="@(y == ViewBag.Year ? "selected" : null)">
                                @y
                            </option>
                        }
                    </select>

                    <a asp-action="Index" asp-route-year="@(ViewBag.Year + (ViewBag.Month == 12 ? 1 : 0))"
                        asp-route-month="@(ViewBag.Month == 12 ? 1 : ViewBag.Month + 1)"
                        class="btn btn-outline-secondary">
                        <i class="bi bi-chevron-right"></i>
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel"></i> Фильтровать
                    </button>
                </div>
            </form>
        </div>
        <div class="card card-full">
            <div class="card-body" style="padding-top: 20px">
                <table class="table table-fixed align-middle">
                    <thead>
                        <tr>
                            <th class="col table-column-header text-center" scope="col">Штраф</th>
                            <th class="col table-column-header text-center" scope="col">Кому</th>
                            <th class="col table-column-header text-center" scope="col">От кого</th>
                            <th class="col table-column-header text-center" scope="col">Дата создания</th>
                            <th class="col table-column-header text-center" scope="col">Объяснение</th>
                            <th class="col table-column-header text-center" scope="col"></th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.EmployeePenalties.Any())
                        {
                            <tr class="table-row empty-table-identificator">
                                <td> Тут пока нет замечаний</td>
                                <td></td>
                                <td></td>
                                <td></td>
                            </tr>
                        }

                        @foreach (var vm in Model.EmployeePenalties)
                        {
                            var employeePenalty = vm.EmployeePenalty;
                            if (employeePenalty == null) continue;
                            <tr>
                                <td class="text-center" style="max-width: 250px;">
                                    <div class="explanation-text">@employeePenalty.Penalty.Description</div>
                                </td>
                                <td class="text-center">
                                    <div class="overflow-auto" style="max-width: 150px;">
                                        @employeePenalty.Employee.GetShortName()
                                    </div>
                                </td>
                                <td class="text-center">
                                    @employeePenalty.Author.GetShortName()
                                </td>
                                <td class="text-center">
                                    @employeePenalty.Created.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td class="text-center" style="max-width: 250px;">
                                    <div class="explanation-text">@employeePenalty.Explanation</div>
                                </td>
                                <td class="text-center">
                                    <a asp-controller="EmployeePenalties" asp-action="Edit"
                                        asp-route-id="@employeePenalty.Id" class="btn btn-secondary" role="button">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .explanation-text {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: normal;
    }
</style>
