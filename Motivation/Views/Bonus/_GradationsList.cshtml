@model Bonus

<tr id="gradations-@Model.Id" class="bg-light">
    <td colspan="2" class="p-0">
        <div class="p-3">
            <table class="table table-sm table-bordered bg-white mb-2">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th style="width: 120px;">Цена</th>
                        <th style="width: 100px;"></th>
                    </tr>
                </thead>
                <tbody id="gradations-tbody-@Model.Id">
                    @foreach (var gradation in Model.Gradations.OrderBy(g => g.Price))
                    {
                        <tr data-gradation-id="@gradation.Id" data-label="@gradation.Label" data-price="@gradation.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            <td class="gradation-label-cell">@gradation.Label</td>
                            <td class="gradation-price-cell">@gradation.Price.ToString("F2")</td>
                            <td>
                                <a href="#" class="edit-gradation-toggle text-primary me-2" data-mode="view">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="#" class="delete-button text-danger" data-id="@gradation.Id">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3">
                            <button type="button" class="btn btn-success btn-sm create-gradation" data-bonus-id="@Model.Id">
                                <i class="bi bi-plus-circle me-1"></i>Создать градацию
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </td>
</tr>