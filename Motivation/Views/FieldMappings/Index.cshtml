@model IEnumerable<Motivation.Models.FieldMapping>

@{
    ViewData["Title"] = "Настройки маппинга полей";
    var portalId = ViewBag.PortalId as int? ?? 0;
    var entityType = ViewBag.EntityType as string ?? "Department";
    var entityTypes = ViewBag.EntityTypes as string[] ?? new[] { "Department", "Employee", "EmployeeTask" };
}

<div class="container mt-4">
    <h1>Настройки маппинга полей Bitrix24</h1>
    
    <div class="mb-3">
        <a asp-action="Index" asp-controller="BitrixSettings" class="btn btn-secondary">← Назад к настройкам порталов</a>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5>Фильтр</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <input type="hidden" name="portalId" value="@portalId" />
                <div class="col-md-4">
                    <label class="form-label">Тип сущности</label>
                    <select name="entityType" class="form-select">
                        @foreach (var type in entityTypes)
                        {
                            <option value="@type" selected="@(type == entityType)">@type</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">Применить</button>
                </div>
            </form>
        </div>
    </div>

    <div class="mb-3">
        <a asp-action="Create" asp-route-portalId="@portalId" asp-route-entityType="@entityType" class="btn btn-success">
            + Добавить маппинг
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Для сущности <strong>@entityType</strong> не найдено настроек маппинга.
            Добавьте новые настройки, чтобы синхронизация работала корректно.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Локальное поле</th>
                    <th>Код в Bitrix24</th>
                    <th>Тип маппинга</th>
                    <th>Активно</th>
                    <th>Описание</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mapping in Model)
                {
                    <tr>
                        <td><code>@mapping.LocalFieldName</code></td>
                        <td><code>@mapping.BitrixCode</code></td>
                        <td>@mapping.MappingType</td>
                        <td>
                            @if (mapping.IsActive)
                            {
                                <span class="badge bg-success">Да</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Нет</span>
                            }
                        </td>
                        <td>@mapping.Description</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@mapping.Id" class="btn btn-sm btn-primary">Изменить</a>
                            <form asp-action="Delete" asp-route-id="@mapping.Id" asp-route-portalId="@portalId" asp-route-entityType="@entityType" method="post" class="d-inline" onsubmit="return confirm('Удалить этот маппинг?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="alert alert-warning mt-4">
        <h6>Справка:</h6>
        <ul>
            <li><strong>Локальное поле</strong> - имя свойства в C# модели (например, <code>Cost</code>, <code>Name</code>)</li>
            <li><strong>Код в Bitrix24</strong> - код поля в API Битрикс24 (например, <code>BUDGET</code>, <code>UF_CRM_123</code>)</li>
            <li><strong>Тип маппинга</strong> - способ преобразования данных (Direct - прямое соответствие)</li>
        </ul>
    </div>
</div>
