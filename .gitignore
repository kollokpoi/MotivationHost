```gitignore
# Build artifacts and binaries
*.exe
*.dll
*.so
*.a
*.obj
*.out
*.pdb
*.ilk

# Dependencies
node_modules/
venv/
.venv/
__pycache__/
.mypy_cache/
.pytest_cache/
target/
.gradle/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```